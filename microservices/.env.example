# ══════════════════════════════════════════════════════════════════════════════
# Savvy — root .env for docker-compose
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in values marked CHANGE_ME
# 3. Run start.ps1 (Windows) or start.sh (Mac/Linux)
#
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
# Use "development" locally. "production" triggers fatal guard if SECRET_KEY
# is still the default value.
ENVIRONMENT=development

# ── JWT (shared across ALL 7 services — must be identical everywhere) ─────────
# Minimum 32 characters. Generate with the command above.
SECRET_KEY=dev-secret-key-change-before-going-to-production!!

# ── CORS (api-gateway) ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── AWS (bank-service + statement-analysis-service) ───────────────────────────
# Required for bank statement upload and AI analysis.
# Leave as-is to skip those features locally.
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET=savvy-bank-statements

# ── Field encryption (user-service — encrypts PII columns like phone_number) ──
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Keep separate from SECRET_KEY — different rotation cadence
FIELD_ENCRYPTION_KEY=CHANGE_ME

# ── ChromaDB vector database auth ─────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CHROMA_AUTH_TOKEN=CHANGE_ME

# ── Internal service signing (HMAC — shared across ALL services) ──────────────
# Gateway signs every outbound request; downstream services verify the HMAC-SHA256 sig.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SERVICE_SECRET=CHANGE_ME

# ── AI providers (statement-analysis-service + ai-recommendation-service) ─────
# Required for AI recommendations and statement analysis.
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=CHANGE_ME

# Optional — only needed if you switch AI_PROVIDER to "openai"
OPENAI_API_KEY=

# ── Email / SMTP (notification-service — leave blank to disable email) ────────
# Email notifications work without this. Leave blank if not needed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── OneSignal push (notification-service — leave blank to disable push) ───────
# Push notifications work without this. Leave blank if not needed.
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
