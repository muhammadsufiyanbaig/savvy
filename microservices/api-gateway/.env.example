# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_NAME=api-gateway
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── JWT (MUST match SECRET_KEY in all other services) ────────────────────────
# Gateway validates JWT without hitting any DB — pure CPU decode (~0.3ms)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256

# ── Rate limiting ─────────────────────────────────────────────────────────────
# DB 6 reserved for api-gateway rate limiting
REDIS_URL=redis://redis:6379/6
# Max requests per window for authenticated users
RATE_LIMIT_AUTH=300
# Max requests per window for unauthenticated IPs
RATE_LIMIT_ANON=60
# Window duration in seconds
RATE_LIMIT_WINDOW=60

# ── Downstream service URLs ───────────────────────────────────────────────────
# These must match container/service names in docker-compose
USER_SERVICE_URL=http://user-service:8001
FINANCE_SERVICE_URL=http://finance-service:8002
BANK_SERVICE_URL=http://bank-service:8003
STATEMENT_SERVICE_URL=http://statement-analysis-service:8004
AI_SERVICE_URL=http://ai-recommendation-service:8005
NOTIFICATION_SERVICE_URL=http://notification-service:8006

# ── HTTP connection pool ───────────────────────────────────────────────────────
# Total max concurrent connections to all upstream services combined
HTTP_POOL_MAX_CONNECTIONS=100
# Max idle keep-alive connections (reused to skip TCP handshake)
HTTP_POOL_MAX_KEEPALIVE=20
# Request timeout in seconds (applies to each upstream call)
HTTP_TIMEOUT=30.0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Only the API gateway needs CORS — downstream services are not browser-accessible
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
