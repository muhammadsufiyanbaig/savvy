# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_NAME=AI Recommendation Service
VERSION=1.0.0
DEBUG=false
PORT=8005

# ── JWT (MUST match SECRET_KEY in all other services) ────────────────────────
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256

# ── AI (Claude) ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# Recommended: claude-sonnet-4-6 (fast) or claude-opus-4-7 (best quality)
CLAUDE_MODEL=claude-sonnet-4-6
# Optional OpenAI fallback
OPENAI_API_KEY=sk-CHANGE_ME

# ── ChromaDB (user investment context storage) ────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Redis (recommendation cache — 1hr TTL) ────────────────────────────────────
# DB 4 reserved for ai-recommendation-service
REDIS_URL=redis://redis:6379/4
RECOMMENDATION_CACHE_TTL=3600

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=financial_
KAFKA_GROUP_ID=ai-service-group

# ── Market data ───────────────────────────────────────────────────────────────
YAHOO_FINANCE_ENABLED=true
# Optional: Alpha Vantage for additional market data
ALPHA_VANTAGE_API_KEY=CHANGE_ME

# ── Processing ────────────────────────────────────────────────────────────────
LANGGRAPH_ENABLED=true
# Max seconds a LangGraph workflow may run before timeout
WORKFLOW_TIMEOUT=60
# Recommendations below this confidence score are filtered out
CONFIDENCE_THRESHOLD=0.75

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
