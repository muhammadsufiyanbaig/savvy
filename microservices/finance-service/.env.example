# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_NAME=Finance Service
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://finance_service:CHANGE_ME@finance-db:5432/finance_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# DB 1 reserved for finance-service
REDIS_URL=redis://redis:6379/1

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=financial_
KAFKA_GROUP_ID=finance-service-group

# ── JWT (MUST match SECRET_KEY in all other services) ────────────────────────
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256

# ── Internal service URLs ─────────────────────────────────────────────────────
USER_SERVICE_URL=http://user-service:8001
NOTIFICATION_SERVICE_URL=http://notification-service:8006
AI_SERVICE_URL=http://ai-recommendation-service:8005

# ── Business rules ────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=USD
# Alert when budget/spending-limit reaches this % (0-100)
BUDGET_ALERT_THRESHOLD=80.0
SPENDING_LIMIT_ALERT_THRESHOLD=80.0

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
