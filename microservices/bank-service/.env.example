# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_NAME=Bank Service
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
PORT=8003

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://bank_service:CHANGE_ME@bank-db:5432/bank_db

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=financial_
KAFKA_GROUP_ID=bank-service-group

# ── JWT (MUST match SECRET_KEY in all other services) ────────────────────────
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256

# ── AWS S3 (for statement file storage) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET=savvy-bank-statements
# Presigned URL expiry in seconds (default 1 hour)
S3_PRESIGNED_URL_EXPIRES=3600

# ── File upload limits ────────────────────────────────────────────────────────
# Max upload size in bytes (default 50 MB)
MAX_FILE_SIZE_BYTES=52428800
ALLOWED_FILE_TYPES=["pdf","csv","xlsx","xls"]

# ── Internal service URLs ─────────────────────────────────────────────────────
USER_SERVICE_URL=http://user-service:8001

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
