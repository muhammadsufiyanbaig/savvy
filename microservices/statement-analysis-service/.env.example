# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_NAME=Statement Analysis Service
VERSION=1.0.0
DEBUG=false
PORT=8004

# ── JWT (MUST match SECRET_KEY in all other services) ────────────────────────
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256

# ── AWS S3 (statement file downloads) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
S3_BUCKET_NAME=savvy-bank-statements

# ── AI Providers (at least one required) ─────────────────────────────────────
# Primary: Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# Fallback: OpenAI
OPENAI_API_KEY=sk-CHANGE_ME
# Which provider to use first: "claude" or "openai"
AI_PROVIDER=claude
AI_MODEL=claude-sonnet-4-6
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=60

# ── ChromaDB (vector similarity for transaction categorization) ───────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=transaction_patterns

# ── Redis (processing status cache) ──────────────────────────────────────────
# DB 3 reserved for statement-analysis-service
REDIS_URL=redis://redis:6379/3
REDIS_CACHE_TTL=3600

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=financial_
KAFKA_GROUP_ID=statement-service-group

# ── Processing limits ─────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_TRANSACTIONS_PER_STATEMENT=1000
# Confidence below this → rule-based fallback
CONFIDENCE_THRESHOLD=0.7

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
