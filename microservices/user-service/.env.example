# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_NAME=User Service
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://user_service:CHANGE_ME@user-db:5432/user_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# DB 0 reserved for user-service (token blacklist + brute-force counters)
REDIS_URL=redis://redis:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=financial_
KAFKA_GROUP_ID=user-service-group

# ── JWT (MUST match across ALL services) ─────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list. Use exact origins in production, never "*"
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
