# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_NAME=notification-service
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://notif_service:CHANGE_ME@notification-db:5432/notification_db

# ── Redis (unread count cache) ────────────────────────────────────────────────
# DB 5 reserved for notification-service
REDIS_URL=redis://redis:6379/5

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=financial_
KAFKA_GROUP_ID=notification-service-group

# ── JWT (MUST match SECRET_KEY in all other services) ────────────────────────
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256

# ── SMTP email delivery (optional — leave blank to disable email channel) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM_EMAIL=notifications@savvy.com
SMTP_FROM_NAME=Savvy
SMTP_USE_TLS=true

# ── OneSignal push notifications (optional — leave blank to disable push) ─────
# Create a free app at https://onesignal.com
ONESIGNAL_APP_ID=CHANGE_ME
ONESIGNAL_API_KEY=CHANGE_ME

# ── Notification behaviour ────────────────────────────────────────────────────
MAX_NOTIFICATIONS_PER_PAGE=50
# Suppress duplicate notifications within this window (seconds)
DEDUP_WINDOW_SECONDS=60
# Notifications older than this are auto-expired
NOTIFICATION_TTL_DAYS=30
# Redis TTL for unread count cache (seconds)
UNREAD_COUNT_CACHE_TTL=60

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
