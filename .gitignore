# ── Environment files (NEVER commit secrets) ──────────────────────────────────
.env
.env.*
!.env.example
*.env
*.env.local
*.env.production

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
*.pyo
*.pyd

# Pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.db           # SQLite test databases
test_ci.db

# Alembic (keep migrations, skip compiled cache)
microservices/**/alembic/__pycache__/

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
frontend/.env*
!frontend/.env.example

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Kubernetes secrets (never commit real secrets) ────────────────────────────
k8s/secrets/*.yaml
!k8s/secrets/external-secret.yaml   # template only — no real values

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── AWS ──────────────────────────────────────────────────────────────────────
.aws/credentials
*.pem
*.key

# ── mTLS dev certs (generated by scripts/generate-dev-certs.sh) ──────────────
microservices/certs/

# ── Test artifacts ───────────────────────────────────────────────────────────
*.xml
junit*.xml
